{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Freedback",
  "version": "0.1.0",
  "identifier": "net.freedback.app",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Freedback",
        "width": 420,
        "height": 820
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ]
  },
  "plugins": {
    "deep-link": {
      "mobile": [
        {
          "scheme": ["freedback"]
        },
        {
          "host": "freedback.net",
          "pathPrefix": ["/l"]
        }
      ],
      "desktop": {
        "schemes": ["freedback"]
      }
    }
  }
}
